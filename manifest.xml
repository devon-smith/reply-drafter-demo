<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reply Drafter (Demo) — minimal Outlook add-in.
  PURPOSE: prove that a custom add-in can install on this account (Gate 1) and that
  Office.js can read the open email and open a prefilled reply. No backend, no AI, no Graph.

  BEFORE SIDELOADING: find-and-replace every occurrence of
      https://REPLACE-ME.example.com
  with the base URL where you host taskpane.html / commands.html / the icons.
  (See README.md — GitHub Pages is the least-friction option on a locked-down machine.)
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- Regenerate this GUID if you fork the demo (any UUID v4 works). -->
  <Id>3f2a7c14-9b6e-4d21-a8f3-1c5e9d0b7a42</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>ReplyDrafterDemo</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Reply Drafter (Demo)"/>
  <Description DefaultValue="Reads the open email and opens a prefilled reply. A connectivity/permission test for custom Outlook add-ins."/>
  <IconUrl DefaultValue="https://REPLACE-ME.example.com/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://REPLACE-ME.example.com/icon-128.png"/>
  <SupportUrl DefaultValue="https://REPLACE-ME.example.com/"/>

  <AppDomains>
    <AppDomain>https://REPLACE-ME.example.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- Fallback UI for older clients that ignore VersionOverrides. -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://REPLACE-ME.example.com/taskpane.html"/>
        <RequestedHeight>280</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- Item-level permission only. This is an Outlook add-in permission (declared here),
       NOT a Microsoft Graph scope, so it does not trigger the tenant admin-consent flow. -->
  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="functionFile"/>

          <!-- Button shown on the ribbon when reading a message. -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="paneButtonLabel"/>
                  <Supertip>
                    <Title resid="paneButtonLabel"/>
                    <Description resid="paneButtonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://REPLACE-ME.example.com/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://REPLACE-ME.example.com/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://REPLACE-ME.example.com/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://REPLACE-ME.example.com/commands.html"/>
        <bt:Url id="taskpaneUrl" DefaultValue="https://REPLACE-ME.example.com/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Reply Drafter"/>
        <bt:String id="paneButtonLabel" DefaultValue="Draft reply"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonTip" DefaultValue="Read this email and open a prefilled reply."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
