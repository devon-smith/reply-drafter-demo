ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=3000
BEHIND_PROXY=1
SITE_HOST=reply-devon.duckdns.org
# Optional shared secret for cross-origin callers (e.g. the Gmail add-on).
# If unset, /draft enforces nothing and the same-origin Outlook pane works as-is.
# If set, cross-origin requests must send it as the x-api-key header.
# API_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
# Optional Supabase per-user config (Gmail multi-user track). Both must be set
# to enable per-user KB/prompt lookup. The SERVICE key bypasses RLS and must
# stay server-side only — never in any client or committed file.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
# Anthropic pricing (USD per 1M tokens) for usage_event.est_cost_usd. Set to your
# model's actual rates; defaults are 3 / 15 if unset.
# PRICE_INPUT_PER_MTOK=3
# PRICE_OUTPUT_PER_MTOK=15
# Cost guardrails (per user). Daily caps are Supabase-backed; RATE_LIMIT is in-memory.
# DAILY_TOKEN_CAP=500000
# DAILY_REQUEST_CAP=100
# RATE_LIMIT_PER_MIN=10
